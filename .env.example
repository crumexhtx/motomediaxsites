# Canonical site origin used for metadata, sitemap, and JSON-LD.
# Use your production domain in production; set preview URLs on Vercel previews.
NEXT_PUBLIC_SITE_URL=https://motomediax.com

# Auto.dev API key for offline catalog enrichment (pnpm enrich:autodev).
# Server/scripts only — never expose in client code. Get a key at https://www.auto.dev/
AUTODEVAPI=

# YouTube Data API v3 key for offline video enrichment (python scripts/fetch-toyota-videos.py).
# Server/scripts only — never expose in client code. Alias YOUTUBEKEY also works.
YOUTUBE_API_KEY=
